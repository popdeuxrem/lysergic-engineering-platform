{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specs.lysergic.dev/ecp/v1/relationship.schema.json",
  "title": "ECP Relationship Schema",
  "description": "Schema for ECP governed relationships (L1).",
  "type": "object",
  "properties": {
    "relationship_type": { "type": "string" },
    "source_id": { "type": "string" },
    "target_id": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
  },
  "required": ["relationship_type", "source_id", "target_id", "version"],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specs.lysergic.dev/extensions/v1/extension.schema.json",
  "title": "LEP Extension Manifest Schema",
  "description": "Schema for LEP extension manifest (extension.yaml) files.",
  "type": "object",
  "properties": {
    "extension_id": { "type": "string", "description": "Unique extension identifier." },
    "name": { "type": "string", "description": "Human-readable extension name." },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$", "description": "Semantic version." },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "optional_dependencies": { "type": "array", "items": { "type": "string" } },
    "capabilities": { "type": "array", "items": { "type": "string" } },
    "permissions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "resource": { "type": "string" },
          "actions": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["resource", "actions"]
      }
    },
    "min_sdk_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "max_sdk_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "entry_point": { "type": "string" },
    "homepage": { "type": "string" },
    "license": { "type": "string" }
  },
  "required": ["extension_id", "name", "version"],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specs.lysergic.dev/workflows/v1/step.schema.json",
  "title": "LEP Workflow Step Schema",
  "description": "Schema for LEP workflow step definitions.",
  "type": "object",
  "properties": {
    "step_id": { "type": "string" },
    "name": { "type": "string" },
    "step_type": { "type": "string", "enum": ["task", "conditional", "parallel", "sub_workflow"] },
    "description": { "type": "string" },
    "contract": { "type": "string" },
    "timeout_seconds": { "type": "integer", "minimum": 0 },
    "retry_count": { "type": "integer", "minimum": 0 }
  },
  "required": ["step_id", "name", "step_type"],
  "additionalProperties": false
}
